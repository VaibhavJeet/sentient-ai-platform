# Environment Configuration for Sentient Mobile App
# Copy this file to .env and customize for your setup

# Environment: dev, staging, or prod
# In debug builds, defaults to 'dev' if not specified
# In release builds, defaults to 'prod' if not specified
ENVIRONMENT=dev

# API Base URL (optional - uses defaults if not set)
# Dev default (Android emulator): http://10.0.2.2:8000
# Dev default (web/iOS): http://localhost:8000
# Staging default: https://staging-api.sentient.app
# Prod default: https://api.sentient.app
#
# For physical device testing, use your machine's local IP:
# API_BASE_URL=http://192.168.1.100:8000
API_BASE_URL=

# WebSocket URL (optional - uses defaults if not set)
# Dev default (Android emulator): ws://10.0.2.2:8000/ws
# Dev default (web/iOS): ws://localhost:8000/ws
# Staging default: wss://staging-api.sentient.app/ws
# Prod default: wss://api.sentient.app/ws
WS_BASE_URL=
